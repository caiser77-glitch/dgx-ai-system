<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aurum.pipeline.tracker</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/USER/AurumPipeline/scripts/track_pipeline_status.py</string>
    <string>--root</string>
    <string>/Users/USER/AI_BASE</string>
    <string>watch</string>
    <string>--interval</string>
    <string>5</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/USER/AI_BASE/logs/track_pipeline_status.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/USER/AI_BASE/logs/track_pipeline_status.err.log</string>
</dict>
</plist>
