# 텔레그램 알림. 실제 값은 이 파일에 커밋하지 말고 운영 환경에만 설정한다.
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_ID=

# 실제 HWP/PDF 변환 엔진 연결 명령.
# 실행 시 DRAFT_PATH, JOB_ID, PUBLISH_DIR, OUTPUT_HWP, OUTPUT_PDF, OUTPUT_DOCX 환경변수가 전달된다.
